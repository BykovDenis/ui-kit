{
  "name": "@sber-risks-ui/icons",
  "version": "0.0.2",
  "description": "Risks react UI",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "author": "Denis Bykov",
  "license": "MIT",
  "scripts": {
    "build": "../node_modules/.bin/rollup -c rollup.config.prod.js",
    "build-dev": "../node_modules/.bin/rollup -w -c rollup.config.dev.js",
    "prepare-ui-kit": "lerna bootstrap && lerna run build && git reset --hard",
    "publish-ui-kit": "npm publish --registry https://nexus-ci.delta.sbrf.ru/repository/npm-release/",
    "clean-node-modules": "rm -rf ../node_modules"
  },
  "publishConfig": {
    "registry": "https://nexus-ci.delta.sbrf.ru/repository/npm-release/"
  },
  "devDependencies": {
    "@babel/plugin-syntax-jsx": "^7.14.5",
    "@babel/preset-react": "^7.18.6",
    "@svgr/rollup": "^6.2.0",
    "@types/react": "18.0.26",
    "@types/react-dom": "18.0.1",
    "autoprefixer": "^10.4.0",
    "babel-core": "^6.26.3",
    "babel-runtime": "^6.26.0",
    "eslint-config-prettier": "8.6.0",
    "prettier": "2.8.3",
    "rollup": "^2.61.1",
    "rollup-plugin-cleaner": "^1.0.0",
    "rollup-plugin-dts": "^4.1.0",
    "rollup-plugin-react-svg": "^3.0.3",
    "rollup-plugin-terser": "^7.0.2",
    "rollup-plugin-typescript2": "^0.31.1",
    "rollup-pluginutils": "^2.8.2",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  }
}
