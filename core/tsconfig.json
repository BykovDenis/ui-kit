{
  "compilerOptions": {
    "rootDir": "./packages",
    "baseUrl": ".",
    "outDir": "build",
    "jsx": "react-jsx",
    "target": "es5",
    "module": "esnext",
    "noImplicitAny": true,
    "sourceMap": false,
    "allowJs": true,
    "checkJs": false,
    "allowSyntheticDefaultImports": true,
    "preserveConstEnums": true,
    "moduleResolution": "node",
    "lib": ["dom", "dom.iterable", "esnext"],
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "exclude": [
    "node_modules",
    "build",
    "__tests__"
  ],
  "include": ["**/*", "node_modules"],
  "extends": "@sbol/cypress-config/cypress/tsconfig.json"
}