{
  "name": "@dbykov-ui-kit/list",
  "description": "List interactive component of the @dbykov-ui-kit library",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "private": true,
  "exports": {
    "require": "./dist/index.js",
