{
  "compilerOptions": {
    "rootDir": "./",
    "baseUrl": "./",
    "outDir": "dist",
    "jsx": "react-jsx",
    "target": "es5",
    "module": "esnext",
    "noImplicitAny": false,
    "sourceMap": true,
    "allowJs": true,
    "checkJs": false,
    "allowSyntheticDefaultImports": true,
    "preserveConstEnums": true,
    "moduleResolution": "bundler",
    "lib": ["dom", "dom.iterable", "esnext"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["vite/client", "node"]
  },
  "exclude": [
    "dist"
  ],
  "include": ["**/*", "../.storybook"]
}
