{
  "compilerOptions": {
    "rootDir": "./",
    "baseUrl": "./",
    "paths": {
      "@dbykov-ui-kit/*": ["./*/src"]
    },
    "outDir": "dist",
    "jsx": "react-jsx",
    "target": "es5",
    "module": "esnext",
    "strict": true,
    "sourceMap": true,
    "allowJs": true,
    "checkJs": false,
    "allowSyntheticDefaultImports": true,
    "preserveConstEnums": true,
    "moduleResolution": "node",
    "lib": ["dom", "dom.iterable", "esnext"],
    "skipLibCheck": true,
    "esModuleInterop": true,
  },
  "exclude": [
    "dist",
    "**/*.stories.*"
  ],
  "include": ["**/*",]
}