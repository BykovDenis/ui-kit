{
  "compilerOptions": {
    "rootDir": "./",
    "baseUrl": "./",
    "outDir": "./temp/types",
    "jsx": "react-jsx",
    "target": "esnext",
    "module": "esnext",
    "noImplicitAny": false,
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "preserveConstEnums": true,
    "moduleResolution": "node",
    "lib": ["dom", "dom.iterable", "esnext"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["vite/client", "node", "react", "react-dom"],
    "declaration": false,
    "emitDeclarationOnly": false,
    "resolveJsonModule": true
  },
  "exclude": ["dist", "**/__tests__/**", "**/*.test.ts", "**/*.test.tsx"],
  "include": ["packages/**/*", "src/**/*", "./types"],
}
