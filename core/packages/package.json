{
  "name": "@sber-risks-ui/core",
  "version": "0.12.2-alpha.3",
  "description": "Risks react UI",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "author": "Denis Bykov",
  "license": "MIT",
  "scripts": {
    "build": "rollup -c rollup.config.prod.js",
    "build-dev": "rollup -w -c rollup.config.dev.js",
    "prepare-ui-kit": "lerna bootstrap && lerna run build && git reset --hard",
    "publish-ui-kit": "npm publish --registry https://nexus-ci.delta.sbrf.ru/repository/npm-release/",
    "clean-node-modules": "rm -rf node_modules"
  },
  "publishConfig": {
    "registry": "https://nexus-ci.delta.sbrf.ru/repository/npm-release/"
  },
  "devDependencies": {
    "rollup": "^2.61.1",
    "rollup-plugin-cleaner": "^1.0.0",
    "rollup-plugin-dts": "^4.1.0",
    "rollup-plugin-image-base64": "^1.0.0",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-react-svg": "^3.0.3",
    "rollup-plugin-scss": "^3.0.0",
    "rollup-plugin-svg": "^2.0.0",
    "rollup-plugin-terser": "^7.0.2",
    "rollup-plugin-typescript2": "0.36.0",
    "rollup-pluginutils": "^2.8.2"
  },
  "dependencies": {
    "debounce": "^1.2.1",
    "styled-components": "5.3.3"
  },
  "peerDependencies": {
    "react": ">=16.8.6",
    "react-dom": ">=16.8.6"
  },
  "workspaces": [
    "./*"
  ]
}
