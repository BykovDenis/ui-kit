{
  "name": "@sber-risks-ui/core",
  "version": "0.12.2-alpha.3",
  "description": "Risks react UI",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "author": "Denis Bykov",
  "license": "MIT",
  "scripts": {
    "build": "rollup -c rollup.config.prod.js",
    "build-dev": "rollup -w -c rollup.config.dev.js",
    "prepare-ui-kit": "lerna bootstrap && lerna run build && git reset --hard",
    "publish-ui-kit": "npm publish --registry https://nexus-ci.delta.sbrf.ru/repository/npm-release/",
    "clean-node-modules": "rm -rf node_modules"
  },
  "publishConfig": {
    "registry": "https://nexus-ci.delta.sbrf.ru/repository/npm-release/"
  },
  "devDependencies": {
    "rollup": "^2.61.1"
  },
  "dependencies": {
    "debounce": "^1.2.1",
    "styled-components": "5.3.3"
  },
  "peerDependencies": {
    "react": ">=16.8.6",
    "react-dom": ">=16.8.6"
  }
}