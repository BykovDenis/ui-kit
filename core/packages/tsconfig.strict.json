{
  // Incremental strict migration (IMPROVEMENT_PLAN.md 4.3): packages listed in
  // "include" must type-check with strict: true. New/migrated packages are
  // added here; once every package is in, fold strict into tsconfig.json.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noEmit": true
  },
  "include": [
    "button/**/*",
    "checkbox/**/*",
    "constants/**/*",
    "customs-styled-components/**/*",
    "divider/**/*",
    "enums/**/*",
    "file-uploader/**/*",
    "flex-container/**/*",
    "form-control/**/*",
    "grid-container/**/*",
    "helpers/**/*",
    "icon-button/**/*",
    "icons-components/**/*",
    "input/**/*",
    "label/**/*",
    "label-interactive/**/*",
    "list/**/*",
    "list-item/**/*",
    "multi-select/**/*",
    "popup/**/*",
    "portal/**/*",
    "progress-bar/**/*",
    "radio/**/*",
    "select/**/*",
    "src/**/*",
    "sticky-bottom-panel/**/*",
    "styles/**/*",
    "switcher/**/*",
    "tab/**/*",
    "table/**/*",
    "table-body/**/*",
    "table-cell/**/*",
    "table-columns-visible/**/*",
    "table-head/**/*",
    "table-row/**/*",
    "tabs/**/*",
    "textfield/**/*",
    "types/**/*",
    "typography/**/*",
    "utilities/**/*",
    "warning-panel/**/*"
  ],
  "exclude": [
    "**/dist",
    "**/node_modules",
    "**/__tests__",
    "**/*.test.*",
    "**/*.stories.*"
  ]
}
