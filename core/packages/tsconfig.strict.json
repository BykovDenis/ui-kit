{
  // Incremental strict migration (IMPROVEMENT_PLAN.md 4.3): packages listed in
  // "include" must type-check with strict: true. New/migrated packages are
  // added here; once every package is in, fold strict into tsconfig.json.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noEmit": true
  },
  "include": [
    "constants/**/*",
    "enums/**/*",
    "helpers/**/*",
    "styles/**/*",
    "types/**/*",
    "utilities/**/*"
  ],
  "exclude": [
    "**/dist",
    "**/node_modules",
    "**/__tests__",
    "**/*.test.ts",
    "**/*.stories.*"
  ]
}
