{
  "verbose": true,
  "preset": "ts-jest",
  "testEnvironment": "jsdom",
  "globals": {
    "ts-jest": {
      "isolatedModules": true
    }
  },
  "transform": {
    "^.+\\.jsx?$": "babel-jest",
    "^.+\\.tsx?$": "ts-jest"
  },
  "moduleNameMapper": {
    "\\.(css|less|scss|sass)$": "identity-obj-proxy"
  },
  "moduleDirectories": ["<rootDir>", "node_modules"],
  "collectCoverage": true,
  "collectCoverageFrom": [
    "**/*.{tsx, js, jsx}",
    "!**/*.d.ts",
    "**/*.ts",
    "!**/node_modules/**",
    "!**/vendor/**",
    "!**/backend-contracts/**",
    "!**/clients/**",
    "!**/constants/**",
    "!**/types/**",
    "!**/enums/**",
    "!**/__mocks__/**",
    "!**/data/**"
  ],
  "coverageDirectory": "<rootDir>/coverage/jest"
}
