                                          npm publish --registry https://nexus-ci.delta.sbrf.ru/repository/npm-release/
                                      """
                                  }
                              }
                          }
                      }
                   }
                }
            }
        }
    }
    post {
        always {
            cleanWs disableDeferredWipeout: true, deleteDirs: true
        }
    }
}
